OPENAI_API_KEY=<your-api-key>
OPENAI_MODEL=gpt-4o-mini

OLLAMA_MODEL=qwen2.5:0.5b 

JUDGE_API_KEY=<my-judge-api-key>  # I would not use a an API for the judge because of latency and cost (n_trials of calls), it can be a local model
JUDGE_MODEL=qwen2.5:1.5b          # Use a more powerful model for the judge to ensure better evaluation quality

OLLAMA_BASE_URL=http://localhost:11434

HF_TOKEN=<your-huggingface-token> # Read only is enough
# LLM Backend Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama Configuration (Pointing to Host)
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Judge/Scorer Config
JUDGE_MODEL=llama3.2:1b
JUDGE_API_KEY=any-string-for-local

# Imprimer System Config
IMPRIMER_GATEWAY_URL=http://localhost:8080
EMBEDDER_MODEL=all-MiniLM-L6-v2
HF_TOKEN=your-token-here

# Database Config
USE_POSTGRES=false
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=imprimer
POSTGRES_PASSWORD=imprimer_secret
POSTGRES_DB=imprimer_registry